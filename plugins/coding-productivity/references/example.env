# coding-productivity configuration
# This file is created by /coding-productivity:setup
# Keep this file private — it contains API tokens and the pseudonymization key.
# NEVER commit this file to version control.

# ─── Platform & Authentication ───────────────────────────────────────
PLATFORM=github                          # github | gitlab
GITHUB_TOKEN=                            # GitHub token (needs repo read scope). Auto-detected from gh CLI.
GITLAB_TOKEN=                            # GitLab token (needs read_api scope). Auto-detected from glab CLI.
GITLAB_URL=                              # Only for self-hosted GitLab (e.g., https://gitlab.example.com)
GITLAB_CA_BUNDLE=                        # Path to custom CA bundle for self-hosted GitLab

# ─── Repositories ────────────────────────────────────────────────────
REPOS=                                   # Comma-separated: owner/repo1,owner/repo2

# ─── Storage ─────────────────────────────────────────────────────────
STORAGE_BACKEND=duckdb                   # duckdb | bigquery
STORAGE_MODE=readwrite                   # readwrite | readonly (set automatically by /connect)
DB_PATH=.coding-productivity/data.duckdb # Local DuckDB file path
GCP_PROJECT_ID=                          # Only for BigQuery backend
BQ_DATASET=                              # Only for BigQuery backend
GOOGLE_APPLICATION_CREDENTIALS=          # Path to GCP service account JSON (BigQuery only)

# ─── AI Scoring (optional) ───────────────────────────────────────────
SCORING_ENABLED=false
ANTHROPIC_API_KEY=                       # Required only if scoring is enabled

# ─── Anonymization ───────────────────────────────────────────────────
ANONYMIZATION_ENABLED=true
PSEUDONYMIZATION_KEY=                    # Auto-generated 32-byte hex. BACK THIS UP.
                                         # Losing it means existing hashes become unresolvable.

# ─── Developer Management ────────────────────────────────────────────
EXCLUDED_DEVELOPERS=                     # Comma-separated canonical emails or hashes
BOT_OVERRIDES=                           # Additional bot identifiers (comma-separated)
IDENTITY_MERGES=                         # Format: alias1=canonical,alias2=canonical
